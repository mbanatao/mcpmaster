# Safe defaults: no provider network, remote service, webhooks, or external writes.
META_NETWORK_ENABLED=false
META_KILL_SWITCH=true
META_REMOTE_MCP_ENABLED=false
META_WEBHOOKS_ENABLED=false
META_EXTERNAL_WRITES_ENABLED=false

# Exact comma-separated Facebook Page IDs. Wildcards are rejected.
META_ALLOWED_PAGE_IDS=

# Provider application metadata. These values are not secrets.
META_APP_ID=
META_GRAPH_API_VERSION=

# Server-side secret references only. Never paste tokens or app secrets here.
# The current container entry point supports env://VARIABLE_NAME references whose
# values are injected through the deployment platform's encrypted secret store.
META_TOKEN_SECRET_REF=
META_WEBHOOK_SECRET_REF=
META_WEBHOOK_VERIFY_TOKEN_SECRET_REF=
META_ENCRYPTION_KEY_REF=
META_SUPABASE_SERVICE_KEY_SECRET_REF=

# Official read-provider controls.
META_REQUEST_TIMEOUT_MS=10000

# Webhooks remain disabled until a deliberate HTTPS ingress is configured.
META_WEBHOOK_MAX_BODY_BYTES=262144

# Remote MCP service. HTTPS is required by default and should terminate at the
# trusted reverse proxy directly in front of this container.
META_REMOTE_MCP_HOST=127.0.0.1
META_REMOTE_MCP_PORT=3200
META_REMOTE_MCP_REQUIRE_HTTPS=true
META_REMOTE_MCP_ALLOWED_ORIGINS=
META_REMOTE_MCP_ORGANIZATION_ID=
META_REMOTE_MCP_INSTALLATION_ID=
META_REMOTE_MCP_BODY_LIMIT_BYTES=262144
META_REMOTE_MCP_REQUESTS_PER_MINUTE=60
META_REMOTE_MCP_AUTH_TIMEOUT_MS=8000

# Supabase public connection metadata. The publishable key is not a server secret;
# staff access tokens are supplied per request and remain subject to RLS.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
META_SUPABASE_REQUEST_TIMEOUT_MS=10000

# Staging readiness is a separate fail-closed command. It validates configuration,
# previews linked Supabase migrations, and calls only the allowlisted Page read.
MCPMASTER_ENVIRONMENT=staging
META_STAGING_READ_ONLY_VALIDATION_ENABLED=false
META_STAGING_BASE_URL=
META_STAGING_ORIGIN=
META_STAGING_EXPECTED_PAGE_ID=
META_STAGING_ACCESS_TOKEN_SECRET_REF=env://META_STAGING_STAFF_TOKEN
META_STAGING_SMOKE_TIMEOUT_MS=10000
META_STAGING_MAX_RESPONSE_BYTES=1048576

# The referenced staff token is supplied only to the smoke-test process through an
# encrypted CI/deployment secret. Never commit its value.
META_STAGING_STAFF_TOKEN=

# Forbidden raw-secret variable names include:
# META_ACCESS_TOKEN
# META_PAGE_ACCESS_TOKEN
# META_APP_SECRET
# META_WEBHOOK_SECRET
# META_WEBHOOK_VERIFY_TOKEN
# META_ENCRYPTION_KEY
# SUPABASE_SERVICE_ROLE_KEY
# SUPABASE_SECRET_KEY
# META_SUPABASE_SERVICE_KEY
