# Foundation defaults: no network and writes disabled.
META_NETWORK_ENABLED=false
META_KILL_SWITCH=true

# Exact comma-separated Facebook Page IDs. Wildcards are rejected.
META_ALLOWED_PAGE_IDS=

# Provider application metadata. This is not a secret.
META_APP_ID=

# Server-side secret references only. Do not paste raw secrets or tokens here.
META_TOKEN_SECRET_REF=
META_WEBHOOK_SECRET_REF=
META_ENCRYPTION_KEY_REF=

# Forbidden raw-secret variable names include:
# META_ACCESS_TOKEN
# META_PAGE_ACCESS_TOKEN
# META_APP_SECRET
# META_WEBHOOK_SECRET
# META_ENCRYPTION_KEY
