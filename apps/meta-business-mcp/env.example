# Safe defaults: no provider network and no external writes.
META_NETWORK_ENABLED=false
META_KILL_SWITCH=true

# Exact comma-separated Facebook Page IDs. Wildcards are rejected.
META_ALLOWED_PAGE_IDS=

# Provider application metadata. These values are not secrets.
META_APP_ID=
META_GRAPH_API_VERSION=

# Server-side secret references only. Never paste tokens or app secrets here.
META_TOKEN_SECRET_REF=
META_WEBHOOK_SECRET_REF=
META_WEBHOOK_VERIFY_TOKEN_SECRET_REF=
META_ENCRYPTION_KEY_REF=

# Official read-provider controls.
META_REQUEST_TIMEOUT_MS=10000

# Webhooks remain disabled until an HTTPS ingress is deliberately configured.
META_WEBHOOKS_ENABLED=false
META_WEBHOOK_MAX_BODY_BYTES=262144

# Forbidden raw-secret variable names include:
# META_ACCESS_TOKEN
# META_PAGE_ACCESS_TOKEN
# META_APP_SECRET
# META_WEBHOOK_SECRET
# META_WEBHOOK_VERIFY_TOKEN
# META_ENCRYPTION_KEY
