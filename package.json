{
  "name": "edenos-mcp-bridge",
  "version": "1.0.0",
  "description": "MCPMaster approval-gated workflow and connector runtime",
  "main": "dist/http-server.js",
  "scripts": {
    "build:runtime": "tsc -p tsconfig.json",
    "build:shared-security": "tsc -p packages/shared-security/tsconfig.json",
    "build:meta": "tsc -p apps/meta-business-mcp/tsconfig.json",
    "build": "npm run build:runtime && npm run build:shared-security && npm run build:meta",
    "check": "tsc -p tsconfig.json --noEmit && npm run build:shared-security && tsc -p apps/meta-business-mcp/tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.js packages/shared-security/test/*.test.js apps/meta-business-mcp/test/*.test.js",
    "start": "node dist/http-server.js",
    "dev": "ts-node src/http-server.ts",
    "start:mcp": "node dist/mcp-stdio.js",
    "dev:mcp": "ts-node src/mcp-stdio.ts",
    "start:meta-remote": "node apps/meta-business-mcp/dist/remote-server.js",
    "dev:meta-remote": "ts-node apps/meta-business-mcp/src/remote-server.ts",
    "meta:staging:validate": "npm run build:meta && node apps/meta-business-mcp/dist/staging-cli.js validate",
    "meta:staging:prove-access": "npm run build:meta && node apps/meta-business-mcp/dist/staging-cli.js prove-access",
    "meta:staging:smoke": "npm run build:meta && node apps/meta-business-mcp/dist/staging-cli.js smoke",
    "aws-deploy": "aws/deploy.sh",
    "aws-deploy-win": "powershell -ExecutionPolicy Bypass -File aws/deploy.ps1",
    "aws-deploy-complete": "aws/deploy-complete.sh",
    "aws-deploy-complete-win": "powershell -ExecutionPolicy Bypass -File aws/deploy-complete.ps1",
    "aws-setup": "aws/setup-aws.sh",
    "aws-setup-win": "powershell -ExecutionPolicy Bypass -File aws/setup-aws.ps1",
    "docker-build": "docker build -t edenos-mcp-bridge .",
    "docker-run": "docker run -p 3000:3000 --env-file .env edenos-mcp-bridge"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "workflow",
    "approval-gates",
    "audit",
    "github",
    "meta-business",
    "law-office"
  ],
  "author": "EdenOS Team",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.4.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "zod": "^3.22.4",
    "node-fetch": "^3.3.2",
    "ws": "^8.14.2",
    "three": "^0.158.0",
    "telegraf": "^4.15.0",
    "@slack/web-api": "^6.10.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/ws": "^8.5.10",
    "@types/three": "^0.158.3",
    "typescript": "^5.3.0",
    "ts-node": "^10.9.0",
    "@vercel/node": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
