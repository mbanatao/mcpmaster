# MCPMaster secure runtime environment
# Copy to .env. Never commit real credentials.

# Server
NODE_ENV=production
PORT=3000

# Required for every protected HTTP endpoint. Use at least 32 random characters.
BRIDGE_ADMIN_TOKEN=replace-with-a-long-random-admin-token

# Required before write or destructive tools can execute over HTTP.
# Keep this distinct from BRIDGE_ADMIN_TOKEN.
BRIDGE_APPROVAL_TOKEN=replace-with-a-different-long-random-approval-token

# Comma-separated browser origins. Leave blank for server-to-server access only.
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_MS=60000

# MCP stdio defaults to read-only. Enable only for a trusted local process.
MCP_ALLOW_WRITES=false

# Initial priority integrations
GITHUB_TOKEN=your-github-token
NOTION_API_KEY=your-notion-api-key
LINEAR_API_KEY=your-linear-api-key
OPENAI_API_KEY=your-openai-api-key
OPENAI_ORGANIZATION=
OPENAI_DEFAULT_MODEL=gpt-4o
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_KEY=
FIREBASE_API_KEY=

# Google Cloud
GCP_PROJECT_ID=your-gcp-project-id
GCP_SERVICE_ACCOUNT_KEY=
GCP_REGION=us-central1
GCP_ZONE=us-central1-a

# Figma
FIGMA_ACCESS_TOKEN=your-figma-access-token

# Zapier
ZAPIER_API_KEY=your-zapier-api-key

# Bnd
BND_API_KEY=your-bnd-api-key
BND_NETWORK=mainnet

# Saviynt
SAVIYNT_API_KEY=your-saviynt-api-key
SAVIYNT_TENANT_ID=your-saviynt-tenant-id

# Neon
NEON_API_KEY=your-neon-api-key
NEON_PROJECT_ID=your-neon-project-id

# DeepMind / experimental adapter
DEEPMIND_API_KEY=your-deepmind-api-key
DEEPMIND_PROJECT_ID=your-deepmind-project-id

# Box
BOX_ACCESS_TOKEN=your-box-access-token
BOX_CLIENT_ID=
BOX_CLIENT_SECRET=
